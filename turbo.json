{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],  
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]  
    },
    "lint": {
    },
    "type-check": {
    },
    "dev": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["build", "test", "lint"]  
    }
  }
}
